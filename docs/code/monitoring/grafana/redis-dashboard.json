{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source with redis_exporter metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "description": "Redis monitoring dashboard: ops/sec, memory usage, keyspace hits/misses, connected clients, evictions, and replication status.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "title": "Ops / sec",
      "description": "Total commands processed per second",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50000 },
              { "color": "red", "value": 100000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        { "expr": "rate(redis_commands_processed_total{instance=~\"$instance\"}[5m])", "legendFormat": "ops/s", "refId": "A" }
      ]
    },
    {
      "title": "Memory Used",
      "description": "Total memory used by Redis including overhead",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2147483648 },
              { "color": "red", "value": 4294967296 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        { "expr": "redis_memory_used_bytes{instance=~\"$instance\"}", "legendFormat": "used", "refId": "A" }
      ]
    },
    {
      "title": "Hit Rate",
      "description": "Keyspace hit rate — percentage of key lookups that found the key",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{instance=~\"$instance\"}[5m]) / (rate(redis_keyspace_hits_total{instance=~\"$instance\"}[5m]) + rate(redis_keyspace_misses_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "hit rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Connected Clients",
      "description": "Number of connected client connections",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 5000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        { "expr": "redis_connected_clients{instance=~\"$instance\"}", "legendFormat": "clients", "refId": "A" }
      ]
    },
    {
      "title": "Evictions / sec",
      "description": "Keys evicted per second due to maxmemory policy",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        { "expr": "rate(redis_evicted_keys_total{instance=~\"$instance\"}[5m])", "legendFormat": "evictions/s", "refId": "A" }
      ]
    },
    {
      "title": "Uptime",
      "description": "Time since Redis server started",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "green", "value": 86400 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "none", "colorMode": "background" },
      "targets": [
        { "expr": "redis_uptime_in_seconds{instance=~\"$instance\"}", "legendFormat": "uptime", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Operations",
      "type": "row"
    },
    {
      "title": "Commands / sec by Type",
      "description": "Commands processed per second broken down by command type (GET, SET, DEL, etc.)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "topk(10, rate(redis_commands_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{ cmd }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Command Latency (p99)",
      "description": "99th percentile latency per command type in seconds",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "topk(10, redis_commands_duration_seconds_total{instance=~\"$instance\"} / redis_commands_total{instance=~\"$instance\"})",
          "legendFormat": "{{ cmd }}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Memory",
      "type": "row"
    },
    {
      "title": "Memory Usage",
      "description": "Redis memory: used vs maxmemory, plus RSS and fragmentation",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "maxmemory" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "redis_memory_used_bytes{instance=~\"$instance\"}", "legendFormat": "used", "refId": "A" },
        { "expr": "redis_memory_used_rss_bytes{instance=~\"$instance\"}", "legendFormat": "RSS", "refId": "B" },
        { "expr": "redis_memory_max_bytes{instance=~\"$instance\"}", "legendFormat": "maxmemory", "refId": "C" }
      ]
    },
    {
      "title": "Memory Fragmentation Ratio",
      "description": "Ratio of RSS to used memory. Values > 1.5 indicate fragmentation; values < 1.0 indicate swapping.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "thresholdsStyle": { "mode": "line+area" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1.0 },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 2.0 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "redis_memory_used_rss_bytes{instance=~\"$instance\"} / redis_memory_used_bytes{instance=~\"$instance\"}",
          "legendFormat": "frag ratio",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Keyspace & Clients",
      "type": "row"
    },
    {
      "title": "Keyspace Hits vs Misses",
      "description": "Rate of key lookups that found the key (hits) vs did not (misses)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "hits" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "misses" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(redis_keyspace_hits_total{instance=~\"$instance\"}[5m])", "legendFormat": "hits", "refId": "A" },
        { "expr": "rate(redis_keyspace_misses_total{instance=~\"$instance\"}[5m])", "legendFormat": "misses", "refId": "B" }
      ]
    },
    {
      "title": "Connected Clients Over Time",
      "description": "Number of client connections and blocked clients",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 31,
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "blocked" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "redis_connected_clients{instance=~\"$instance\"}", "legendFormat": "connected", "refId": "A" },
        { "expr": "redis_blocked_clients{instance=~\"$instance\"}", "legendFormat": "blocked", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Evictions & Expiry",
      "type": "row"
    },
    {
      "title": "Evictions & Expired Keys",
      "description": "Rate of keys being evicted (maxmemory) and expired (TTL)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 40,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "evicted" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "expired" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(redis_evicted_keys_total{instance=~\"$instance\"}[5m])", "legendFormat": "evicted", "refId": "A" },
        { "expr": "rate(redis_expired_keys_total{instance=~\"$instance\"}[5m])", "legendFormat": "expired", "refId": "B" }
      ]
    },
    {
      "title": "Total Keys by Database",
      "description": "Number of keys stored in each Redis database (db0, db1, etc.)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 41,
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "redis_db_keys{instance=~\"$instance\"}", "legendFormat": "{{ db }}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 105,
      "title": "Replication",
      "type": "row"
    },
    {
      "title": "Replication Offset Lag",
      "description": "Byte offset lag between master and replicas",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "id": 50,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "showPoints": "never", "thresholdsStyle": { "mode": "line" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1048576 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "redis_master_repl_offset{instance=~\"$instance\"} - on(instance) redis_connected_slave_offset_bytes{instance=~\"$instance\"}",
          "legendFormat": "slave {{ slave_ip }}:{{ slave_port }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Connected Replicas",
      "description": "Number of connected replica instances",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "id": 51,
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "textMode": "value_and_name" },
      "targets": [
        { "expr": "redis_connected_slaves{instance=~\"$instance\"}", "legendFormat": "{{ instance }}", "refId": "A" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["redis", "cache"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(redis_up, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "multi": true,
        "name": "instance",
        "query": { "query": "label_values(redis_up, instance)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Redis Overview",
  "uid": "redis-overview",
  "version": 1
}
